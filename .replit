modules = ["rust-stable"]
run = "cargo run --release"
entrypoint = "dotless-rs/src/main.rs"
hidden = [".config", ".git", "node_modules", "dist", "target"]

[nix]
channel = "stable-24_05"

[packager]
language = "rust"

[packager.features]
packageSearch = true

[languages.rust]
pattern = "**/*.rs"

[languages.rust.languageServer]
start = "rust-analyzer"

[deployment]
deploymentTarget = "gce"
build = ["sh", "-c", "cargo build --release"]
run = ["sh", "-c", "./dotless-rs/target/release/dotless-rs"]

[[ports]]
localPort = 8080
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dotless Rust App"

[[workflows.workflow]]
name = "Dotless Rust App"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cargo run --release"
waitForPort = 8080
